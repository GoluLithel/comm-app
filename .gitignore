# ----------------------------------------------------------------------------
# Combined .gitignore for CommApp (backend + frontend)
# Patterns are unrooted so they match in any subdirectory
# (comm-app-backend/, comm-app-frontend/, etc.)
# ----------------------------------------------------------------------------

# Dependencies
node_modules/
comm-app-reactjs-fe
comm-app-nodejs-be

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Tests / coverage
coverage/
.nyc_output/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Temp directories
.temp
.tmp

# OS files
.DS_Store

# Windows "mark of the web" alternate-data-stream files (from WSL/Windows copies)
*:Zone.Identifier

# Editors / IDEs
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# IDE - VSCode (keep shared project settings)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
